{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": ["components/*"],
      "@services/*": ["services/*"],
      "@stores/*": ["stores/*"],
      "@hooks/*": ["hooks/*"],
      "@constants/*": ["constants/*"],
      "@app-types/*": ["./shared-types/*"]
    }
  }
}